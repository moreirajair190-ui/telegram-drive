# ====================================================================
# TgPlayer Web — configuração do BACKEND (multiusuário)
# Copie para ".env" e ajuste os valores. NUNCA versione o .env real.
# ====================================================================

# --------------------------------------------------------------------
# 0) BANCO DE DADOS (OBRIGATÓRIO em produção) — Supabase Postgres
# --------------------------------------------------------------------
# Toda a persistência (usuários, credenciais Telegram cifradas, sessões
# cifradas, cursos, aulas, progresso, tarefas) vai para o Postgres do
# Supabase. NÃO é necessário NENHUM disco/arquivo local no servidor.
#
# No painel do Supabase: Project Settings -> Database -> Connection string
# (use a "Connection pooling"/porta 6543 OU a direta 5432). Formato:
#   postgresql://postgres:SUA_SENHA@db.SEU_PROJ.supabase.co:5432/postgres?sslmode=require
#
# Aceita DATABASE_URL ou SUPABASE_DB_URL (equivalentes). O backend adiciona
# sslmode=require automaticamente se faltar.
DATABASE_URL=postgresql://postgres:SUA_SENHA@db.SEU_PROJ.supabase.co:5432/postgres?sslmode=require
# SUPABASE_DB_URL=  # alternativa equivalente a DATABASE_URL

# (Apenas DEV/local) Se NÃO definir DATABASE_URL, cai para um SQLite local.
# Caminho do arquivo (NUNCA usado em produção). Padrão: ao lado do backend.
# TGWEB_SQLITE_PATH=./tgplayer_web.sqlite3

# --------------------------------------------------------------------
# 1) CHAVE DE CRIPTOGRAFIA (OBRIGATÓRIA em produção)
# --------------------------------------------------------------------
# Usada para cifrar (Fernet) API_ID, API_HASH, session string e telefone
# de cada usuário ANTES de gravar no banco. Se você perder/trocar esta
# chave, TODAS as credenciais já cifradas ficam ilegíveis.
#
# Gere uma chave nova com:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=cole-aqui-a-chave-fernet-gerada

# (Opcional) Rotação de chaves: lista separada por vírgula. A 1ª cifra,
# as demais ainda conseguem decifrar dados antigos.
#   ENCRYPTION_KEYS=chave_nova,chave_antiga
# ENCRYPTION_KEYS=

# (Apenas DEV) Permite rodar SEM ENCRYPTION_KEY usando uma chave efêmera
# (os dados cifrados somem ao reiniciar). NUNCA use em produção.
# TGWEB_ALLOW_EPHEMERAL_KEY=0

# --------------------------------------------------------------------
# 2) SEGREDO DO JWT (OBRIGATÓRIO em produção)
# --------------------------------------------------------------------
# Assina os tokens de sessão (HS256). Se mudar, todos os logins caem.
#   python -c "import secrets; print(secrets.token_hex(32))"
TGWEB_SECRET=cole-aqui-um-segredo-longo-e-aleatorio

# Expiração da sessão em horas (padrão 72 = 3 dias).
# TGWEB_TOKEN_HOURS=72

# --------------------------------------------------------------------
# 3) ADMINISTRADOR INICIAL (opcional)
# --------------------------------------------------------------------
# Provisiona um admin no primeiro boot. O admin NÃO vê dados sensíveis
# (API_ID/HASH/session/tokens) de ninguém — só o painel agregado.
# TGWEB_ADMIN_EMAIL=admin@seudominio.com
# TGWEB_ADMIN_PASSWORD=troque-esta-senha-forte

# --------------------------------------------------------------------
# 4) REGISTRO DE NOVOS USUÁRIOS
# --------------------------------------------------------------------
# 1 = qualquer um pode criar conta (padrão). 0 = registro fechado.
# TGWEB_ALLOW_REGISTRATION=1

# --------------------------------------------------------------------
# 5) SEGURANÇA / RATE LIMITING
# --------------------------------------------------------------------
# Login do site (proteção contra brute force).
# TGWEB_LOGIN_MAX_FAILURES=5
# TGWEB_LOGIN_WINDOW_SECONDS=900          # 15 minutos

# Pedido de código do Telegram (evita flood/bloqueio na conta do usuário).
# TGWEB_TG_SENDCODE_MAX=4
# TGWEB_TG_SENDCODE_WINDOW=3600           # 1 hora

# Política mínima de senha do site.
# TGWEB_PASSWORD_MIN_LENGTH=8

# --------------------------------------------------------------------
# 6) SERVIDOR
# --------------------------------------------------------------------
TGWEB_HOST=0.0.0.0
# O Render injeta a variável PORT automaticamente. Localmente use 8800.
TGWEB_PORT=8800

# --------------------------------------------------------------------
# 7) CORS — domínio do frontend (Cloudflare Pages)
# --------------------------------------------------------------------
# Liste os domínios permitidos separados por vírgula. "*" só em dev.
# Ex.: TGWEB_CORS=https://tgplayer.pages.dev,https://app.seudominio.com
TGWEB_CORS=*

# --------------------------------------------------------------------
# 8) CACHE DE STREAMING (EFÊMERO — não é persistência)
# --------------------------------------------------------------------
# Buffer temporário de bytes do vídeo durante o streaming. Pode sumir no
# restart sem qualquer perda. Em produção fica em /tmp. NÃO precisa de disco.
# TGWEB_STREAM_CACHE_DIR=/tmp/tgplayer-streams
#
# OBS: NÃO use mais TGPLAYER_DATA / /var/data / disco persistente do Render.
# A persistência é 100% no Postgres do Supabase (variável DATABASE_URL acima).
