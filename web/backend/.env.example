# ============ TgPlayer Web — configuração ============
# Copie este arquivo para ".env" e ajuste os valores.

# ---- Segredo do token (IMPORTANTE: gere um aleatório longo e fixo) ----
# Se mudar, todos os logins existentes são invalidados.
TGWEB_SECRET=mude-para-uma-string-bem-grande-e-aleatoria

# ---- Login do SITE ----
# RECOMENDADO: deixe estas duas linhas comentadas e crie sua conta pela tela
# "Criar conta" do site (login/senha ficam salvos com segurança no banco).
# Só descomente se quiser um login FIXO por env (modo avançado):
# TGWEB_USER=admin
# TGWEB_PASSWORD=troque-esta-senha

# ---- Sua conta do Telegram (https://my.telegram.org) ----
# Se você já usou o app desktop e logou, pode deixar em branco que ele
# reaproveita o que está salvo no banco.
TGWEB_API_ID=
TGWEB_API_HASH=

# ---- Servidor ----
TGWEB_HOST=0.0.0.0
TGWEB_PORT=8800

# ---- CORS: domínio do frontend (Cloudflare). "*" libera tudo (só dev) ----
TGWEB_CORS=*
